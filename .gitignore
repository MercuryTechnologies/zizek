# jujutsu VCS
.jj/*

# envrc & direnv cache
.envrc
.direnv/*

# nix build artifacts
result

# cabal-install build artifacts
dist-newstyle/*
cabal/*

# profiling/release builddirs (just profile-space / profile-time)
dist-newstyle-prof/*
dist-newstyle-release/*

# GHC profiling artifacts
**/*.prof*

# captured profiles (scripts/profile-*.sh output)
profiles/

# local claude settings
.claude/settings.local.json

# engine working directories (constants/unicode caches + example database),
# created at the cwd by libhegel (.hegel) and hegel-core (.hypothesis)
.hegel/
.hypothesis/

# conformance test binaries (built by just check-conformance)
tests/conformance/pytest/bin/*
!tests/conformance/pytest/bin/.gitkeep

# python bytecode cache
__pycache__/

# misc docs
notes/*
