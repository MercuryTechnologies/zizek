# jujutsu VCS
.jj/*

# envrc & direnv cache
.envrc
.direnv/*

# nix build artifacts
result

# cabal-install build artifacts
dist-newstyle/*
cabal/*

# GHC profiling artifacts
**/*.prof*

# local claude settings
.claude/settings.local.json

# conformance test binaries (built by just check-conformance)
tests/conformance/pytest/bin/*
!tests/conformance/pytest/bin/.gitkeep

# python bytecode cache
__pycache__/

# misc docs
refs/*
notes/*
