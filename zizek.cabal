-- Gallery of deliberately-failing stateful machines, each stressing one
-- rendering decision of the rich report renderer; for manual eyeballing.
-- Not run by CI; `just gallery` from the repo root.
executable gallery
  import: conformance
  hs-source-dirs: examples/gallery
  main-is: Main.hs
  build-depends:
    containers ^>=0.7,
    zizek,

-- A guided tour of the failure report's progression, from a plain spliced
-- property to the full composed trace report; for manual eyeballing.
-- Not run by CI; `just tour` from the repo root.
executable tour
  import: conformance
  hs-source-dirs: examples/tour
  main-is: Main.hs
  build-depends:
    containers ^>=0.7,
    unliftio ^>=0.2,
    zizek,

-- Profiling scenarios: deterministic, named workloads isolating the
-- Haskell-side hot paths (see notes/decisions/profiling-harness.md).
-- `cabal run profile-hegel -- --list` for the scenario list; driven by
-- `just profile-run` / `just profile-space` / `just profile-time`.
executable profile-hegel
  import: conformance
  -- -N1 (overriding conformance's -N): the scenarios are single-threaded, and
  -- parallel GC would only add nondeterministic noise to profiles & timings.
  ghc-options: -with-rtsopts=-N1
  hs-source-dirs: tests/profile
  main-is: Main.hs
  other-modules:
    Handles
    Stress
    Warehouse

  build-depends:
    containers ^>=0.7,
    zizek,

test-suite unit
  import: library
  type: exitcode-stdio-1.0
  hs-source-dirs: tests/unit
  main-is: Main.hs
  ghc-options:
    -threaded
    -rtsopts
    -with-rtsopts=-N

  -- cabal-gild: discover tests/unit --exclude=tests/unit/Main.hs
  other-modules:
    BasicProperties
    ControlSignals
    DatabaseReplay
    GeneratorSchemas
    Integrations
    KeyedProperties
    LedgerRendering
    PoolEvents
    PropertyChecks
    ReportRendering
    SourceRendering
    StandardGenerators
    Stateful
    TraceFixtures
    TraceIR

  build-depends:
    hspec ^>=2.11,
    tasty-hspec ^>=1.2,
    zizek,

test-suite ffi
  import: library
  type: exitcode-stdio-1.0
  hs-source-dirs: tests/ffi
  main-is: Main.hs
  pkgconfig-depends: hegel
  -- Closed-world guard: fails to build if libhegel adds an enum variant.
  c-sources: cbits/wire_enum_guard.c
  cc-options: -Werror=switch-enum
  other-modules: WireEnumCoverage
  ghc-options:
    -threaded
    -rtsopts
    -with-rtsopts=-N

  build-depends:
    hspec ^>=2.11,
    tasty-hspec ^>=1.2,
    witch ^>=1.2,
    zizek,
