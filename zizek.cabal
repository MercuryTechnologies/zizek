executable test-origin-deduplication
  import: conformance
  hs-source-dirs: tests/conformance/origin-deduplication
  main-is: Main.hs
  build-depends:
    aeson ^>=2.2,
    zizek,
    zizek:conformance-utils,

executable test-sampled-from
  import: conformance
  hs-source-dirs: tests/conformance/sampled-from
  main-is: Main.hs
  build-depends:
    aeson ^>=2.2,
    zizek,
    zizek:conformance-utils,

executable test-one-of
  import: conformance
  hs-source-dirs: tests/conformance/one-of
  main-is: Main.hs
  build-depends:
    aeson ^>=2.2,
    zizek,
    zizek:conformance-utils,

executable test-text
  import: conformance
  hs-source-dirs: tests/conformance/text
  main-is: Main.hs
  build-depends:
    aeson ^>=2.2,
    zizek,
    zizek:conformance-utils,

executable test-list
  import: conformance
  hs-source-dirs: tests/conformance/list
  main-is: Main.hs
  build-depends:
    aeson ^>=2.2,
    zizek,
    zizek:conformance-utils,

executable test-set
  import: conformance
  hs-source-dirs: tests/conformance/set
  main-is: Main.hs
  build-depends:
    aeson ^>=2.2,
    containers ^>=0.7,
    zizek,
    zizek:conformance-utils,

executable test-map
  import: conformance
  hs-source-dirs: tests/conformance/map
  main-is: Main.hs
  build-depends:
    aeson ^>=2.2,
    containers ^>=0.7,
    zizek,
    zizek:conformance-utils,

executable test-char
  import: conformance
  hs-source-dirs: tests/conformance/char
  main-is: Main.hs
  build-depends:
    aeson ^>=2.2,
    zizek,
    zizek:conformance-utils,

executable test-regex
  import: conformance
  hs-source-dirs: tests/conformance/regex
  main-is: Main.hs
  build-depends:
    aeson ^>=2.2,
    zizek,
    zizek:conformance-utils,

test-suite unit
  import: library
  type: exitcode-stdio-1.0
  hs-source-dirs: tests/unit
  main-is: Main.hs
  ghc-options:
    -threaded
    -rtsopts
    -with-rtsopts=-N

  -- cabal-gild: discover tests/unit --exclude=tests/unit/Main.hs
  other-modules:
    BasicProperties
    GeneratorSchemas
    PipelinedRequests
    SessionRecovery
    StandardGenerators
    TestBackends
    TestRunner
    UnsupportedCapabilities

  build-depends:
    hspec ^>=2.11,
    tasty ^>=1.5,
    tasty-hspec ^>=1.2,
    zizek,

test-suite native
  import: library
  type: exitcode-stdio-1.0
  hs-source-dirs: tests/native
  main-is: Main.hs
  ghc-options:
    -threaded
    -rtsopts
    -with-rtsopts=-N

  build-depends:
    hspec ^>=2.11,
    tasty ^>=1.5,
    tasty-hspec ^>=1.2,
    zizek,
