cabal-version: 3.0
name: zizek
version: 0.0.0
synopsis: Hegel Property Tests
description: Property-based testing for Haskell, built on Hypothesis.
author: jkachmar
copyright: 2026 jkachmar
maintainer: j@mercury.com
license: MPL-2.0
license-file: LICENSE
tested-with: ghc ^>=9.10 && ^>=9.12
build-type: Simple
extra-source-files: licenses/hedgehog.LICENSE

common all
  default-language: GHC2021
  build-depends:
    base ^>=4.20 || ^>=4.21 || ^>=4.22

  default-extensions:
    BlockArguments
    DeriveAnyClass
    DerivingStrategies
    DuplicateRecordFields
    ImportQualifiedPost
    LambdaCase
    NoFieldSelectors
    OverloadedRecordDot
    OverloadedStrings
    PatternSynonyms
    ScopedTypeVariables
    StrictData
    TypeFamilies

  ghc-options:
    -Weverything
    -Wno-all-missed-specialisations
    -Wno-implicit-prelude
    -Wno-missed-specialisations
    -Wno-missing-export-lists
    -Wno-missing-import-lists
    -Wno-missing-kind-signatures
    -Wno-missing-role-annotations
    -Wno-missing-safe-haskell-mode
    -Wno-safe
    -Wno-partial-fields
    -Wno-unsafe
    -Wno-unused-packages

common library
  import: all
  build-depends:
    async ^>=2.2,
    base ^>=4.20 || ^>=4.21 || ^>=4.22,
    bytestring ^>=0.12,
    containers ^>=0.7,
    data-default-class ^>=0.2,
    digest ^>=0.0,
    hashable ^>=1.4 || ^>=1.5,
    hspec-core ^>=2.11.10,
    network-uri ^>=2.6,
    pretty-show ^>=1.10,
    prettyprinter ^>=1.7,
    prettyprinter-ansi-terminal ^>=1.1,
    tasty ^>=1.5,
    text ^>=2.1,
    transformers ^>=0.6,
    unliftio ^>=0.2,
    unordered-containers ^>=0.2,
    uuid ^>=1.3,
    vector ^>=0.13,
    wireform-cbor,
    witch ^>=1.2,

library
  import: library
  hs-source-dirs: library
  pkgconfig-depends: hegel
  -- cabal-gild: discover library
  exposed-modules:
    Hegel
    Hegel.Assertion
    Hegel.Backend
    Hegel.Collection
    Hegel.Database
    Hegel.Diff
    Hegel.Gen
    Hegel.Gen.Binary
    Hegel.Gen.Bool
    Hegel.Gen.Builder
    Hegel.Gen.Char
    Hegel.Gen.Domain
    Hegel.Gen.Float
    Hegel.Gen.HashMap
    Hegel.Gen.HashSet
    Hegel.Gen.IntMap
    Hegel.Gen.IntSet
    Hegel.Gen.Integer
    Hegel.Gen.Internal
    Hegel.Gen.List
    Hegel.Gen.Map
    Hegel.Gen.Regex
    Hegel.Gen.Set
    Hegel.Gen.Text
    Hegel.Gen.Uri
    Hegel.Gen.Uuid
    Hegel.HealthCheck
    Hegel.Hspec
    Hegel.Internal.CBOR
    Hegel.Internal.CString
    Hegel.Internal.Control
    Hegel.Internal.DataSource
    Hegel.Internal.DatabaseKey
    Hegel.Internal.Event
    Hegel.Internal.FFI
    Hegel.Internal.Schema
    Hegel.Internal.TestCase
    Hegel.Phase
    Hegel.Pool
    Hegel.Property
    Hegel.Property.Internal
    Hegel.Report
    Hegel.Report.Ann
    Hegel.Report.Blame
    Hegel.Report.Discovery
    Hegel.Report.Glyph
    Hegel.Report.Journal
    Hegel.Report.Ledger
    Hegel.Report.Note
    Hegel.Report.Phrase
    Hegel.Report.Source
    Hegel.Report.Span
    Hegel.Report.Stateful
    Hegel.Report.Style
    Hegel.Report.Trace
    Hegel.Report.Verdict
    Hegel.Runner
    Hegel.Settings
    Hegel.Stateful
    Hegel.Tasty
    Hegel.Verbosity

  if os(osx)
    frameworks:
      CoreFoundation
      IOKit
      Security

common conformance
  import: library
  ghc-options:
    -threaded
    -rtsopts
    -with-rtsopts=-N

library conformance-utils
  import: library
  visibility: private
  hs-source-dirs: tests/conformance/lib
  exposed-modules: ConformanceUtils
  build-depends:
    aeson ^>=2.2,
    zizek,

executable test-booleans
  import: conformance
  hs-source-dirs: tests/conformance/booleans
  main-is: Main.hs
  build-depends:
